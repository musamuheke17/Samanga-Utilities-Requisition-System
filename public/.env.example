# ============================================
# SAMANGA UTILITIES REQUISITION SYSTEM
# Environment Variables Configuration
# ============================================

# ─── Server ────────────────────────────────
# Port the server will run on
PORT=3000

# ─── Database ──────────────────────────────
# MongoDB connection string
# For local: mongodb://localhost:27017/samanga_requisition
# For cloud: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/samanga_requisition

# ─── Email (Nodemailer) ────────────────────
# Gmail account for sending notifications
# Use App Password (not regular password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# ─── Approval Workflow ─────────────────────
# Emails of approvers in the workflow
# Order: Supervisor → Manager → CEO → Finance
SUPERVISOR_EMAIL=supervisor@company.com
MANAGER_EMAIL=manager@company.com
CEO_EMAIL=ceo@company.com
FINANCE_EMAIL=finance@company.com

# ─── Base URL ──────────────────────────────
# For local development: http://localhost:3000
# For production: https://your-domain.com
BASE_URL=http://localhost:3000